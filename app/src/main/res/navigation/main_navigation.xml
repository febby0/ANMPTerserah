<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/main_navigation"
  app:startDestination="@id/loginFragment">

  <fragment
    android:id="@+id/loginFragment"
    android:name="com.projectnmp.anmpterserah.view.LoginFragment"
    android:label="fragment_login"
    tools:layout="@layout/fragment_login" >
    <action
      android:id="@+id/action_loginFragment_to_dashboardFragment"
      app:destination="@id/dashboardFragment" />
  </fragment>
  <fragment
    android:id="@+id/dashboardFragment"
    android:name="com.projectnmp.anmpterserah.view.DashboardFragment"
    android:label="fragment_dashboard"
    tools:layout="@layout/fragment_dashboard" >
    <action
      android:id="@+id/actionDashboardtoCreateHabit"
      app:destination="@id/createHabitFragment" />
    <argument
      android:name="userId"
      app:argType="string" />
  </fragment>
  <fragment
    android:id="@+id/createHabitFragment"
    android:name="com.projectnmp.anmpterserah.view.CreateHabitFragment"
    android:label="fragment_create_habit"
    tools:layout="@layout/fragment_create_habit" />
</navigation>
